#!/bin/sh
# Git exports GIT_INDEX_FILE / GIT_DIR / GIT_WORK_TREE to hooks. Unset them so
# the test suite's `git worktree` subprocesses operate on their own temp repos
# instead of inheriting this commit's index (which fails with "index file open
# failed: Not a directory").
unset GIT_INDEX_FILE GIT_DIR GIT_WORK_TREE GIT_PREFIX
exec make check
